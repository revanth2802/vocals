# Copy this file to .env for local development.
# Do not commit your real .env file.

# Public app config
# For web on Vercel, the app uses same-origin /api routes automatically.
# For native apps, point to your deployed Vercel URL.
EXPO_PUBLIC_API_BASE_URL=https://your-app.vercel.app

# Local-only fallback for development.
# Do not use this in production client builds.
EXPO_PUBLIC_MINIMAX_API_KEY=your-local-minimax-key-here
EXPO_PUBLIC_OPENAI_TRANSCRIPTION_API_KEY=sk-your-local-openai-transcription-key-here

# Server-only secret for Vercel API routes.
MINIMAX_API_KEY=your-server-minimax-key-here

# Separate speech-to-text provider for audio transcription.
OPENAI_TRANSCRIPTION_API_KEY=sk-your-openai-transcription-key-here
