{
  "expo": {
    "name": "VOCALS",
    "slug": "vocals",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF6F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vocals.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VOCALS needs microphone access to record your voice notes and convert them into actionable tasks.",
        "NSSpeechRecognitionUsageDescription": "VOCALS uses speech recognition to transcribe your voice notes."
      },
      "backgroundColor": "#FBF6F1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#FBF6F1"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.vocals.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "VOCALS needs microphone access to record your voice notes."
        }
      ]
    ]
  }
}